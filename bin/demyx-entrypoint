#!/bin/bash
# Demyx
# https://demyx.sh
set -eEuo pipefail
# shellcheck disable=SC2034
#
#   Entrypoint.
#
demyx_entrypoint() {
    local DEMYX_ENTRYPOINT_I=
    #
    #   Support for old variables
    #
    [[ -n "${NGINX_BASIC_AUTH:-}" ]] && DEMYX_BASIC_AUTH="${NGINX_BASIC_AUTH}"
    [[ -n "${NGINX_BASIC_AUTH_HTPASSWD:-}" ]] && DEMYX_BASIC_AUTH_HTPASSWD="${NGINX_BASIC_AUTH_HTPASSWD}"
    [[ -n "${NGINX_CACHE:-}" ]] && DEMYX_CACHE="${NGINX_CACHE}"
    [[ -n "${NGINX_DOMAIN:-}" ]] && DEMYX_DOMAIN="${NGINX_DOMAIN}"
    [[ -n "${NGINX_RATE_LIMIT:-}" ]] && DEMYX_RATE_LIMIT="${NGINX_RATE_LIMIT}"
    [[ -n "${NGINX_UPLOAD_LIMIT:-}" ]] && DEMYX_UPLOAD_LIMIT="${NGINX_UPLOAD_LIMIT}"
    [[ -n "${NGINX_WHITELIST:-}" ]] && DEMYX_WHITELIST="${NGINX_WHITELIST}"
    [[ -n "${NGINX_WHITELIST_IP:-}" ]] && DEMYX_WHITELIST_IP="${NGINX_WHITELIST_IP}"
    [[ -n "${NGINX_XMLRPC:-}" ]] && DEMYX_XMLRPC="${NGINX_XMLRPC}"
    [[ -n "${WORDPRESS_BEDROCK:-}" ]] && DEMYX_BEDROCK="${WORDPRESS_BEDROCK}"
    source "${DEMYX_CONFIG}/VERSION"
    #
    #   Cloudflare
    #
    [[ -f "${DEMYX_CONFIG}/extra.d/cloudflare.conf" ]] && rm -f "${DEMYX_CONFIG}/extra.d/cloudflare.conf"
    # fetch and update ipv4
    for DEMYX_ENTRYPOINT_I in $(curl -s https://www.cloudflare.com/ips-v4); do
        echo "set_real_ip_from ${DEMYX_ENTRYPOINT_I};" >> "${DEMYX_CONFIG}/extra.d/cloudflare.conf";
    done
    # fetch and update ipv6
    for DEMYX_ENTRYPOINT_I in $(curl -s https://www.cloudflare.com/ips-v6); do
        echo "set_real_ip_from ${DEMYX_ENTRYPOINT_I};" >> "${DEMYX_CONFIG}/extra.d/cloudflare.conf";
    done
    # Proxy check
    {
        if [[ -n "$(curl -m 1 -svo /dev/null "${DEMYX_DOMAIN}" 2>&1 | grep "Server: cloudflare" || true)" ]]; then
            echo "real_ip_header CF-Connecting-IP; set_real_ip_from 0.0.0.0/0;"
        else
            echo "real_ip_header X-Forwarded-For; set_real_ip_from 0.0.0.0/0;"
        fi
    } >> "${DEMYX_CONFIG}/extra.d/cloudflare.conf"
    #
    #   Bedrock
    #
    [[ -f "${DEMYX_CONFIG}/con.d/bedrock.conf" ]] && rm -f "${DEMYX_CONFIG}/con.d/bedrock.conf"
    if [[ "${DEMYX_BEDROCK}" = true ]]; then
        DEMYX="${DEMYX}/web"
        cp "${DEMYX_CONFIG}/con.d/bedrock.cfg" "${DEMYX_CONFIG}/con.d/bedrock.conf"
    fi
    #
    #   Cache
    #
    [[ -f "${DEMYX_CONFIG}/con.d/cache-http.conf" ]] && rm -f "${DEMYX_CONFIG}/con.d/cache-http.conf"
    [[ -f "${DEMYX_CONFIG}/con.d/cache-location.conf" ]] && rm -f "${DEMYX_CONFIG}/con.d/cache-location.conf"
    [[ -f "${DEMYX_CONFIG}/con.d/cache-server.conf" ]] && rm -f "${DEMYX_CONFIG}/con.d/cache-server.conf"
    [[ -f "${DEMYX_CONFIG}/con.d/rocket.conf" ]] && rm -f "${DEMYX_CONFIG}/con.d/rocket.conf"
    if [[ "${DEMYX_CACHE}" = true && "${DEMYX_CACHE_TYPE}" = default ]]; then
        [[ -f "${DEMYX_CONFIG}/con.d/rocket.conf" ]] && rm -f "${DEMYX_CONFIG}/con.d/rocket.conf"
        cp "${DEMYX_CONFIG}/con.d/cache-http.cfg" "${DEMYX_CONFIG}/con.d/cache-http.conf"
        cp "${DEMYX_CONFIG}/con.d/cache-location.cfg" "${DEMYX_CONFIG}/con.d/cache-location.conf"
        cp "${DEMYX_CONFIG}/con.d/cache-server.cfg" "${DEMYX_CONFIG}/con.d/cache-server.conf"
        sed -i "s|DEMYX_CACHE_INACTIVE|${DEMYX_CACHE_INACTIVE}|g" "${DEMYX_CONFIG}"/con.d/cache-http.conf
    elif [[ "${DEMYX_CACHE}" = true && "${DEMYX_CACHE_TYPE}" = rocket ]]; then
        if [[ ! -d "${DEMYX_CONFIG}/custom/nginx/rocket-nginx" ]]; then
            mkdir -p "${DEMYX_CONFIG}/custom/nginx"
            tar -xzf "${DEMYX_CONFIG}/rocket-nginx.tgz" -C "${DEMYX_CONFIG}/custom/nginx"
        fi
        [[ -f "${DEMYX_CONFIG}/con.d/cache-http.conf" ]] && rm -f "${DEMYX_CONFIG}/con.d/cache-http.conf"
        [[ -f "${DEMYX_CONFIG}/con.d/cache-location.conf" ]] && rm -f "${DEMYX_CONFIG}/con.d/cache-location.conf"
        [[ -f "${DEMYX_CONFIG}/con.d/cache-server.conf" ]] && rm -f "${DEMYX_CONFIG}/con.d/cache-server.conf"
        cp "${DEMYX_CONFIG}/con.d/rocket.cfg" "${DEMYX_CONFIG}/con.d/rocket.conf"
        sed -i "s|DEMYX_CONFIG|${DEMYX_CONFIG}|g" "${DEMYX_CONFIG}"/con.d/rocket.conf
    fi
    #
    #   Basic auth
    #
    [[ -f "${DEMYX_CONFIG}/con.d/auth.conf" ]] && rm -f "${DEMYX_CONFIG}/con.d/auth.conf"
    [[ -f "${DEMYX_CONFIG}/con.d/auth-wp.conf" ]] && rm -f "${DEMYX_CONFIG}/con.d/auth-wp.conf"
    if [[ "${DEMYX_BASIC_AUTH}" = true ]]; then
        cp "${DEMYX_CONFIG}/con.d/auth.cfg" "${DEMYX_CONFIG}/con.d/auth.conf"
        sed -i "s|DEMYX_CONFIG|${DEMYX_CONFIG}|g" "${DEMYX_CONFIG}"/con.d/auth.conf
    elif [[ "${DEMYX_BASIC_AUTH_WP}" = true ]]; then
        cp "${DEMYX_CONFIG}/con.d/auth.cfg" "${DEMYX_CONFIG}/con.d/auth-wp.conf"
        sed -i "s|DEMYX_CONFIG|${DEMYX_CONFIG}|g" "${DEMYX_CONFIG}"/con.d/auth-wp.conf
    fi
    htpasswd -Bbn "${DEMYX_BASIC_AUTH_USERNAME}" "${DEMYX_BASIC_AUTH_PASSWORD}" > "${DEMYX_CONFIG}/.htpasswd"
    #
    #   Rate limit
    #
    [[ -f "${DEMYX_CONFIG}/con.d/rate-limit.conf" ]] && rm -f "${DEMYX_CONFIG}/con.d/rate-limit.conf"
    [[ "${DEMYX_RATE_LIMIT}" = true ]] && cp "${DEMYX_CONFIG}/con.d/rate-limit.cfg" "${DEMYX_CONFIG}/con.d/rate-limit.conf"
    #
    #   XMLRPC
    #
    if [[ "${DEMYX_XMLRPC}" = false ]]; then
        cp "${DEMYX_CONFIG}/con.d/xmlrpc.cfg" "${DEMYX_CONFIG}/con.d/xmlrpc.conf"
    else
        [[ -f "${DEMYX_CONFIG}/con.d/xmlrpc.conf" ]] && rm -f "${DEMYX_CONFIG}/con.d/xmlrpc.conf"
    fi
    #
    #   Whitelist
    #
    [[ -f "${DEMYX_CONFIG}/con.d/whitelist.conf" ]] && rm -f "${DEMYX_CONFIG}/con.d/whitelist.conf"
    [[ -f "${DEMYX_CONFIG}/con.d/whitelist-wp.conf" ]] && rm -f "${DEMYX_CONFIG}/con.d/whitelist-wp.conf"
    if [[ "${DEMYX_WHITELIST}" = true || "${DEMYX_WHITELIST}" = all ]]; then
        DEMYX_WHITELIST_IP="${DEMYX_WHITELIST_IP//,/ }"
        for DEMYX_ENTRYPOINT_I in $DEMYX_WHITELIST_IP
        do
            echo "allow ${DEMYX_ENTRYPOINT_I};" >> "${DEMYX_CONFIG}/con.d/whitelist.conf"
        done
        echo "deny all;" >> "${DEMYX_CONFIG}/con.d/whitelist.conf"
    elif [[ "${DEMYX_WHITELIST}" = login ]]; then
        DEMYX_WHITELIST_IP="${DEMYX_WHITELIST_IP//,/ }"
        for DEMYX_ENTRYPOINT_I in $DEMYX_WHITELIST_IP
        do
            echo "allow ${DEMYX_ENTRYPOINT_I};" >> "${DEMYX_CONFIG}/con.d/whitelist-wp.conf"
        done
        echo "deny all;" >> "${DEMYX_CONFIG}/con.d/whitelist-wp.conf"
    fi
    #
    #   Overrides
    #
    [[ ! -d "${DEMYX_CONFIG}/custom/nginx/con.d" ]] && mkdir -p "${DEMYX_CONFIG}/custom/nginx/con.d"
    [[ ! -d "${DEMYX_CONFIG}/custom/nginx/conf.d" ]] && mkdir -p "${DEMYX_CONFIG}/custom/nginx/conf.d"
    [[ ! -d "${DEMYX_CONFIG}/custom/nginx/extra.d" ]] && mkdir -p "${DEMYX_CONFIG}/custom/nginx/extra.d"
    [[ -f "${DEMYX_CONFIG}/custom/nginx/mime.types" ]] && ln -sf "${DEMYX_CONFIG}/custom/nginx/mime.types" "${DEMYX_CONFIG}/mime.types"
    [[ -f "${DEMYX_CONFIG}/custom/nginx/con.d/auth.conf" ]] && ln -sf "${DEMYX_CONFIG}/custom/nginx/con.d/auth.conf" "${DEMYX_CONFIG}/con.d/auth.conf"
    [[ -f "${DEMYX_CONFIG}/custom/nginx/con.d/bedrock.conf" ]] && ln -sf "${DEMYX_CONFIG}/custom/nginx/con.d/bedrock.conf" "${DEMYX_CONFIG}/con.d/bedrock.conf"
    [[ -f "${DEMYX_CONFIG}/custom/nginx/con.d/cache-http.conf" ]] && ln -sf "${DEMYX_CONFIG}/custom/nginx/con.d/cache-http.conf" "${DEMYX_CONFIG}/con.d/cache-http.conf"
    [[ -f "${DEMYX_CONFIG}/custom/nginx/con.d/cache-location.conf" ]] && ln -sf "${DEMYX_CONFIG}/custom/nginx/con.d/cache-location.conf" "${DEMYX_CONFIG}/con.d/cache-location.conf"
    [[ -f "${DEMYX_CONFIG}/custom/nginx/con.d/cache-server.conf" ]] && ln -sf "${DEMYX_CONFIG}/custom/nginx/con.d/cache-server.conf" "${DEMYX_CONFIG}/con.d/cache-server.conf"
    [[ -f "${DEMYX_CONFIG}/custom/nginx/con.d/rate-limit.conf" ]] && ln -sf "${DEMYX_CONFIG}/custom/nginx/con.d/rate-limit.conf" "${DEMYX_CONFIG}/con.d/rate-limit.conf"
    [[ -f "${DEMYX_CONFIG}/custom/nginx/con.d/rocket.conf" ]] && ln -sf "${DEMYX_CONFIG}/custom/nginx/con.d/rocket.conf" "${DEMYX_CONFIG}/con.d/rocket.conf"
    [[ -f "${DEMYX_CONFIG}/custom/nginx/con.d/xmlrpc.conf" ]] && ln -sf "${DEMYX_CONFIG}/custom/nginx/con.d/xmlrpc.conf" "${DEMYX_CONFIG}/con.d/xmlrpc.conf"
    [[ -f "${DEMYX_CONFIG}/custom/nginx/conf.d/brotli.conf" ]] && ln -sf "${DEMYX_CONFIG}/custom/nginx/conf.d/brotli.conf" "${DEMYX_CONFIG}/conf.d/brotli.conf"
    [[ -f "${DEMYX_CONFIG}/custom/nginx/conf.d/common.conf" ]] && ln -sf "${DEMYX_CONFIG}/custom/nginx/conf.d/common.conf" "${DEMYX_CONFIG}/conf.d/common.conf"
    [[ -f "${DEMYX_CONFIG}/custom/nginx/conf.d/gzip.conf" ]] && ln -sf "${DEMYX_CONFIG}/custom/nginx/conf.d/gzip.conf" "${DEMYX_CONFIG}/conf.d/gzip.conf"
    [[ -f "${DEMYX_CONFIG}/custom/nginx/conf.d/headers.conf" ]] && ln -sf "${DEMYX_CONFIG}/custom/nginx/conf.d/headers.conf" "${DEMYX_CONFIG}/conf.d/headers.conf"
    [[ -f "${DEMYX_CONFIG}/custom/nginx/extra.d/assets.conf" ]] && ln -sf "${DEMYX_CONFIG}/custom/nginx/extra.d/assets.conf" "${DEMYX_CONFIG}/extra.d/assets.conf"
    [[ -f "${DEMYX_CONFIG}/custom/nginx/extra.d/cloudflare.conf" ]] && ln -sf "${DEMYX_CONFIG}/custom/nginx/extra.d/cloudflare.conf" "${DEMYX_CONFIG}/extra.d/cloudflare.conf"
    # TEMPORARY - Import old custom conf
    [[ -f "${DEMYX_CONFIG}/custom/nginx/extras/server-00.conf" ]] && cp "${DEMYX_CONFIG}/custom/nginx/extras/server-00.conf" "${DEMYX_CONFIG}/custom/nginx/extra.d/"
    #
    #   Template for nginx.conf
    #
cat << EOF > "${DEMYX_CONFIG}/nginx.conf"
#
#   Demyx v${DEMYX_VERSION} - https://demyx.sh
#
worker_processes auto;
worker_cpu_affinity auto;
worker_rlimit_nofile 100000;
error_log stderr notice;
error_log ${DEMYX_LOG}/${DEMYX_DOMAIN}.error.log;
pid ${DEMYX_CONFIG}/nginx.pid;
pcre_jit on;
load_module /etc/nginx/modules/ngx_http_cache_purge_module.so;
load_module /etc/nginx/modules/ngx_http_headers_more_filter_module.so;
load_module /etc/nginx/modules/ngx_http_brotli_filter_module.so;
load_module /etc/nginx/modules/ngx_http_brotli_static_module.so;

events {
    worker_connections 4000;
    multi_accept on;
    accept_mutex on;
    use epoll;
}

http {
    upstream php {
        server ${DEMYX_WORDPRESS_CONTAINER}:${DEMYX_WORDPRESS_PORT};
    }

    default_type application/octet-stream;
    include /etc/nginx/mime.types;
    include ${DEMYX_CONFIG}/con.d/cache-http[.]conf;
    include ${DEMYX_CONFIG}/custom/nginx/conf.d/*.conf;
    include ${DEMYX_CONFIG}/conf.d/*.conf;

    server {
        listen 80;
        listen [::]:80;
        server_name ${DEMYX_DOMAIN};
        root ${DEMYX};
        index index.php;
        access_log ${DEMYX_LOG}/${DEMYX_DOMAIN}.access.log main;
        error_log ${DEMYX_LOG}/${DEMYX_DOMAIN}.error.log;
        include ${DEMYX_CONFIG}/con.d/cache-server[.]conf;
        include ${DEMYX_CONFIG}/con.d/rocket[.]conf;
        include ${DEMYX_CONFIG}/custom/nginx/extra.d/*.conf;
        include ${DEMYX_CONFIG}/extra.d/*.conf;

        location ~* \.php$ {
            fastcgi_split_path_info ^(.+\.php)(/.*)$;
            if (!-f \$document_root\$fastcgi_script_name) { return 404; }
            fastcgi_param HTTP_PROXY "";
            include fastcgi_params;
            fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
            fastcgi_index index.php;
            fastcgi_pass php;
            include ${DEMYX_CONFIG}/con.d/cache-location[.]conf;
            include ${DEMYX_CONFIG}/con.d/bedrock[.]conf;
        }

        location / {
            include ${DEMYX_CONFIG}/con.d/auth[.]conf;
            include ${DEMYX_CONFIG}/con.d/rate-limit[.]conf;
            include ${DEMYX_CONFIG}/con.d/xmlrpc[.]conf;
            include ${DEMYX_CONFIG}/con.d/whitelist[.]conf;
            try_files \$uri \$uri/ /index.php\$is_args\$args;
        }
    }
}
EOF
    #
    #   Finalize
    #
    sed -e "s|DEMYX_UPLOAD_LIMIT|${DEMYX_UPLOAD_LIMIT}|g" \
        -e "s|DEMYX_CONFIG|${DEMYX_CONFIG}|g" \
        -e "s|DEMYX_VERSION|${DEMYX_VERSION}|g" \
        -e "s|DEMYX_CACHE_INACTIVE|${DEMYX_CACHE_INACTIVE}|g" \
        -i "${DEMYX_CONFIG}"/conf.d/*.conf "${DEMYX_CONFIG}"/extra.d/*.conf
    sudo -E demyx-sudo cron
    sudo -E demyx-sudo permissions
}
#
#   Init.
#
demyx_entrypoint
#
#   Reload nginx, else start
#
if [[ -n "$(pgrep nginx || true)" ]]; then
    nginx -s reload
else
    exec "$@"
fi
